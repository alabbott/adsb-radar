# Copy to .env and fill in your values
# cp .env.example .env

# ── Reticulum hub (optional) ───────────────────────────────────────────────
#
# Leave blank (or omit .env entirely) to run as an isolated local simulation —
# senders and receiver talk only to each other, no traffic leaves the machine.
#
# Uncomment to bridge the cluster to the Chicagoland Reticulum Network (CRN):
#   https://reticulum.world/
#
# RETICULUM_HOST=rns.noderage.org
# RETICULUM_PORT=4242

# ── ADS-B data source ──────────────────────────────────────────────────────
#
# The pre-configured senders in docker-compose.yml use the public adsb.lol API
# (open to everyone, no API key required):
#   https://api.adsb.lol/v2/point/LAT/LON/RANGE_NM
#
# To use a different source, edit --url in docker-compose.yml:
#
#   Local dump1090 / adsb.im (if running on the Docker host):
#     http://host.docker.internal:8080/data/aircraft.json
#
#   adsb.lol feeder passthrough (IP-restricted to active feeders, richer data):
#     https://re-api.adsb.lol?circle=LAT,LON,RANGE_NM
#
#   adsb.exchange (requires API key):
#     https://adsbexchange.com/api/aircraft/v2/lat/LAT/lon/LON/dist/RANGE/
#     Set ADSBX_API_KEY below and pass --api-key $ADSBX_API_KEY to the sender.
#
# ADSBX_API_KEY=your_key_here
